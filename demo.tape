Output assets/ecr-prioritizer-demo.gif
Set Shell "bash"
Set FontSize 18
Set Width 1280
Set Height 900
Set TypingSpeed 40ms
Set PlaybackSpeed 0.8

Type "./bin/ecr-prioritizer --demo"
Enter
Sleep 4s
Down
Sleep 1s
Enter
Sleep 4s
Escape
Sleep 1s
Type "r"
Sleep 2s
Tab
Tab
Tab
Tab
Enter
Sleep 3s
Type "q"
Sleep 1s

Type "./bin/ecr-prioritizer --demo --format md --limit 4"
Enter
Sleep 5s
